# Face Attendance System Configuration
# Copy this file to .env and modify as needed

# Application port (default: 8000)
APP_PORT=8000

# Secret key for JWT tokens - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# Admin credentials - CHANGE THESE IN PRODUCTION!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Face recognition settings
# Threshold: 0.0-1.0 (higher = stricter matching)
# Recommended: 0.55-0.70
FACE_MATCH_THRESHOLD=0.6

# Duplicate attendance prevention (minutes)
DUPLICATE_TIMEOUT=30

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Database (SQLite by default, can be changed to PostgreSQL)
# For PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./data/db/attendance.db
